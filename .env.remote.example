# Remote Supabase for `pnpm dev` / `pnpm dev:remote` / `wrangler dev --env remote`.
# Copy to .env.remote.local and replace YOUR_PASSWORD.
#
# Use the session pooler URI from Supabase → Database → Connection string (port 5432).
# Same value for both vars keeps seed/migrate and wrangler dev in sync.
#
# Cloudflare Hyperdrive origin (dashboard) must also use session pooler :5432.
# Do not use transaction pooler :6543 — deployed DB routes hang with pg/Kysely.

DATABASE_URL=postgresql://postgres.vocnhmoigfqybjhqyatx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://postgres.vocnhmoigfqybjhqyatx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
