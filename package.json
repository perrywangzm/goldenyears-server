{
	"name": "golden-years-server-next",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"build": "wrangler deploy --dry-run --outdir=dist",
		"check:api": "tsx tools/contract-checks/checkApiConventions.ts",
		"check:openapi": "pnpm openapi && git diff --exit-code openapi.json",
		"check:supabase-auth-plan": "vitest run tools/contract-checks/checkSupabaseAuthCompletion.bdd.test.ts && tsx tools/contract-checks/checkSupabaseAuthCompletion.ts",
		"check:dev-profiles": "node --import tsx tools/dev/checkDevProfiles.ts",
		"dev": "wrangler dev --env remote",
		"dev:remote": "wrangler dev --env remote",
		"dev:local": "wrangler dev --env local",
		"dev:stack:local": "node --import tsx tools/dev/devStack.ts start local",
		"dev:stack:remote": "node --import tsx tools/dev/devStack.ts start remote",
		"dev:profile:doctor": "node --import tsx tools/dev/devStack.ts doctor",
		"dev:profile:sync": "node --import tsx tools/dev/devStack.ts sync",
		"dev:supabase:start": "node --import tsx tools/dev/devStack.ts supabase start",
		"dev:supabase:status": "node --import tsx tools/dev/devStack.ts supabase status",
		"dev:supabase:stop": "node --import tsx tools/dev/devStack.ts supabase stop",
		"dev:supabase:reset": "node --import tsx tools/dev/devStack.ts supabase reset",
		"dev:seed:local": "node --import tsx tools/dev/devStack.ts seed-local",
		"deploy": "wrangler deploy",
		"db:migrate": "node --import tsx tools/db/migrate.ts",
		"openapi": "tsx tools/openapi/exportOpenApi.ts",
		"auth:migrate-users": "tsx tools/auth-migration/migrateSupabaseUsers.ts",
		"seed:mockup": "node --import tsx tools/seed-import/importMockupFixtures.ts",
		"smoke:dev-stack:local": "node --import tsx tools/dev/smokeLocalStack.ts",
		"test": "vitest run",
		"test:dev-orchestration-harness": "node --import tsx tools/dev/devOrchestrationHarness.ts",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/zod-openapi": "^1.1.0",
		"hono": "^4.7.11",
		"kysely": "^0.28.8",
		"pg": "^8.16.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@cloudflare/workers-types": "^4.20260518.0",
		"@types/node": "^20.19.35",
		"@types/pg": "^8.15.6",
		"supabase": "2.109.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0",
		"wrangler": "^4.76.0"
	}
}
