# Local Postgres for `pnpm dev:local` / `wrangler dev --env local`.
# Default URI is also committed in wrangler.jsonc env.local.
# Copy to .env.local.local only if you need different host, port, user, or password.
#
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
# CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://postgres:postgres@127.0.0.1:5432/postgres
