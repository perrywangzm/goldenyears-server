# Manual fallback for `pnpm dev:local` / `wrangler dev --env local`.
# Prefer `pnpm dev:stack:local`, which discovers these values from the pinned
# local Supabase CLI and writes the gitignored .env.local.local atomically.
#
# Obtain the current keys with `pnpm exec supabase status --output json`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=YOUR_LOCAL_PUBLISHABLE_KEY
SUPABASE_AUTH_REDIRECT_URL=http://localhost:5173/login
CORS_ORIGIN=http://localhost:5173
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://postgres:postgres@127.0.0.1:54322/postgres
